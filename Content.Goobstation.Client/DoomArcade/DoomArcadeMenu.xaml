<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="UAC Arcade - RIP AND TEAR"
               SetSize="520 420">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" MinHeight="30">
            <Label Name="ScoreLabel" Text="SCORE: 0" HorizontalExpand="True"
                   StyleClasses="LabelMono" />
            <Label Name="HpLabel" Text="HP: 100"
                   StyleClasses="LabelMono" />
            <Label Name="AmmoLabel" Text="AMMO: 50" Margin="10 0 0 0"
                   StyleClasses="LabelMono" />
        </BoxContainer>

        <Control Name="GameContainer" HorizontalExpand="True" VerticalExpand="True"
                 MinHeight="320" MinWidth="480" />

        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" MinHeight="30">
            <Label Text="WASD: Move | Arrows: Turn/Shoot"
       StyleClasses="LabelMono" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
